class Pair{
    int first;
    int second;

    Pair(int first,int second){
        this.first=first;
        this.second=second;
    }
}
class Solution {
    public int orangesRotting(int[][] grid) {
        int m=grid.length;
        int n=grid[0].length;

        boolean[][] vis=new boolean[m][n];
        Queue<Pair> qe=new LinkedList<>();
        int cntfresh=0;

        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]==2){
                    qe.offer(new Pair(i,j));
                }else if(grid[i][j]==1){
                    cntfresh++;
                }
            }
        }
        int delrow[]={-1,0,1,0};
        int delcol[]={0,1,0,-1};
        int time=0;
        while(!qe.isEmpty()){
            boolean rotted=false;
            int size=qe.size();

            for(int i=0;i<size;i++){
                int curRow=qe.peek().first;
                int curCol=qe.peek().second;
                qe.poll();

                for(int k=0;k<4;k++){
                    int nrow=curRow+delrow[k];
                    int ncol=curCol+delcol[k];

                    if(nrow>=0 && nrow<m && ncol >=0 && ncol<n && vis[nrow][ncol]==false && grid[nrow][ncol]==1){
                        vis[nrow][ncol]=true;
                        qe.offer(new Pair(nrow,ncol));
                        cntfresh--;
                        rotted=true;
                    }
                }
            }
            if(rotted) time++;;

        }
        return (cntfresh==0)?time:-1;
    }
}
