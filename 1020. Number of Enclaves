class Solution {

    int delRow[]={-1,0,1,0};
    int delCol[]={0,1,0,-1};

    public void dfs(int row,int col,int[][] grid,boolean vis[][]){
        vis[row][col]=true;

        int m=grid.length;
        int n=grid[0].length;

        for(int i=0;i<4;i++){
            int nRow=row+delRow[i];
            int nCol=col+delCol[i];
            if(nRow>=0 && nCol<n && nRow<m && nCol>=0 && vis[nRow][nCol]==false && grid[nRow][nCol]==1){
                dfs(nRow,nCol,grid,vis);
            }
        }
    }
    public int numEnclaves(int[][] grid) {
        int m=grid.length;
        int n=grid[0].length;
        boolean vis[][]=new boolean[m][n];

        for(int i=0;i<n;i++){

            if(vis[0][i]==false && grid[0][i]==1){
                dfs(0,i,grid,vis);
            }

             if(vis[m-1][i]==false && grid[m-1][i]==1){
                dfs(m-1,i,grid,vis);
            }
        }

        for(int i=0;i<m;i++){

             if(vis[i][0]==false && grid[i][0]==1){
                dfs(i,0,grid,vis);
            }

            if(vis[i][n-1]==false && grid[i][n-1]==1){
                dfs(i,n-1,grid,vis);
            }
        }

        int ans=0;

        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]==1 && vis[i][j]==false){
                    ans++;
                }
            }
        }
        return ans;
    }
}
