/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    class Pair{
        TreeNode node;
        int ind;

        Pair(TreeNode node,int ind){
            this.node=node;
            this.ind=ind;
        }
    }
    public int widthOfBinaryTree(TreeNode root) {
      if(root==null) return 0;

      Queue<Pair> qe=new LinkedList<>();
      qe.offer(new Pair(root,0));
      int ans=0;

      while(!qe.isEmpty()){
        Pair curr=qe.peek();
        int size=qe.size();
        int min=curr.ind;
        int start=0,last=0;

        for(int i=0;i<size;i++){
            int currInd=qe.peek().ind-min;
            TreeNode currNode=qe.peek().node;
            qe.poll();
            if(i==0) start=currInd;
            if(i==size-1) last=currInd;

            if(currNode.left!=null){
                qe.offer(new Pair(currNode.left,2*currInd+1));
            }
            if(currNode.right!=null){
                qe.offer(new Pair(currNode.right,2*currInd+2));
            }
        }
        ans=Math.max(ans,last-start+1);
      }
      return ans;
    }
}
