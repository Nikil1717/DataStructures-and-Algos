/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode(int x) { val = x; }
 * }
 */
class Solution {
    public void markParent(TreeNode root,HashMap<TreeNode,TreeNode> hm){
        if(root==null) return;
        Queue<TreeNode> qe=new LinkedList<>();
        qe.offer(root);

        while(!qe.isEmpty()){
            TreeNode current=qe.poll();

            if(current.left!=null){
                qe.offer(current.left);
                hm.put(current.left,current);
            }
            if(current.right!=null){
                qe.offer(current.right);
                hm.put(current.right,current);
            }
        }
        
    }
    public List<Integer> distanceK(TreeNode root, TreeNode target, int k) {
        HashMap<TreeNode,TreeNode> hm=new HashMap<>();
        markParent(root,hm);
        List<Integer> ans=new ArrayList<>();
        Queue<TreeNode> qe=new LinkedList<>();
        HashMap<TreeNode,Boolean> visited=new HashMap<>();
       
        qe.offer(target);
        visited.put(target,true);
        int dis=0;

        while(!qe.isEmpty()){
            int size=qe.size();
            if(dis==k) break;
            dis++;
            for(int i=0;i<size;i++){
                TreeNode curr=qe.poll();

                if(curr.left!=null && visited.get(curr.left)==null){
                    qe.offer(curr.left);
                    visited.put(curr.left,true);
                }
                if(curr.right!=null && visited.get(curr.right)==null){
                    qe.offer(curr.right);
                    visited.put(curr.right,true);
                }
                if(hm.get(curr)!=null && visited.get(hm.get(curr))==null){
                    qe.offer(hm.get(curr));
                    visited.put(hm.get(curr),true);
                }
            }
        }

        while(!qe.isEmpty()){
            ans.add(qe.poll().val);
        }
        return ans;



    }
}
