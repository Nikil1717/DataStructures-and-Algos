class Pair{
    int first;
    int second;
    int third;
    Pair(int first,int second,int third){
        this.first=first;
        this.second=second;
        this.third=third;
    }
}
class Solution {
    public int[][] updateMatrix(int[][] mat) {
        int m=mat.length;
        int n=mat[0].length;

        ArrayList<ArrayList<Integer>> adj=new ArrayList<>();
        boolean vis[][]=new boolean[m][n];
        int dis[][]=new int[m][n];
        Queue<Pair> qe=new LinkedList<>();

        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(mat[i][j]==0){
                    vis[i][j]=true;
                    qe.offer(new Pair(i,j,0));
                }
            }
        }

        int disrow[]={0,-1,0,1};
        int discol[]={-1,0,1,0};
        while(!qe.isEmpty()){
            int row=qe.peek().first;
            int col=qe.peek().second;
            int steps=qe.peek().third;
            qe.poll();
            dis[row][col]=steps;

            for(int i=0;i<4;i++){
                int nrow=row+disrow[i];
                int ncol=col+discol[i];

                if(nrow>=0 && ncol<n && nrow<m && ncol>=0 && vis[nrow][ncol]!=true){
                    vis[nrow][ncol]=true;
                    qe.offer(new Pair(nrow,ncol,steps+1));
                }
            }

        }
        return dis;

    }
}
