class Solution {
    public void dfs(int node,ArrayList<ArrayList<Integer>> adj,boolean vis[]){
        vis[node]=true;

        for(Integer i:adj.get(node)){
            if(vis[i]==false){
                dfs(i,adj,vis);
            }
        }
    }
    public int findCircleNum(int[][] isConnected) {
        ArrayList<ArrayList<Integer>> adjLis=new ArrayList<>();

        for(int i=0;i<isConnected.length;i++){
            adjLis.add(new ArrayList<>());
        }

        for(int i=0;i<isConnected.length;i++){
            for(int j=0;j<isConnected.length;j++){
                if(isConnected[i][j]==1 && i!=j){
                    adjLis.get(i).add(j);
                    adjLis.get(j).add(i);
                }
            }
        }

        boolean vis[]=new boolean[isConnected.length+1];
        int count=0;
        for(int i=0;i<isConnected.length;i++){
            if(vis[i]==false){
                count++;
                dfs(i,adjLis,vis);
            }
        }
        return count;
    }
}
